{
  "description": "Warp native notifications for Codex CLI",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume|clear)$",
        "hooks": [
          {
            "type": "command",
            "command": "__PLUGIN_ROOT__/scripts/on-session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PLUGIN_ROOT__/scripts/on-user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "__PLUGIN_ROOT__/scripts/on-post-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__PLUGIN_ROOT__/scripts/on-stop.sh"
          }
        ]
      }
    ]
  }
}

